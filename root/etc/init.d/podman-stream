#!/bin/sh /etc/rc.common
# Podman SSE stream daemon - procd-supervised, started on demand by the LuCI
# client (not enabled at boot). procd respawns it on crash.

USE_PROCD=1
START=95
STOP=10

DAEMON=/usr/share/podman/stream-daemon.uc

start_service() {
	procd_open_instance podman-stream
	procd_set_param command /usr/bin/ucode "$DAEMON"
	# respawn: threshold=3600s, restart-delay=5s, retries=0 (unlimited)
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
